APP_NAME=RECALDE
APP_VERSION=1.2.2
APP_DEBUG=0
APP_URL=https://tu-dominio.com

DB_HOST=localhost
DB_NAME=RECALDE
DB_USER=root
DB_PASS=change_me
DB_CHARSET=utf8mb4

# Mail config: mail | smtp | log
MAIL_DRIVER=smtp
MAIL_FROM_ADDRESS=no-reply@recalde.local
MAIL_FROM_NAME=RECALDE

# SMTP options (used only when MAIL_DRIVER=smtp)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# Path used when MAIL_DRIVER=log or when mail sending fails
MAIL_LOG_PATH=/tmp/recalde-mail.log
